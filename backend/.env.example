# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=https://marketplace.nuttzar.website

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./data/marketplace.db

# ── Encryption (generate a random 32+ character string and paste it here) ─────
# Run this in terminal to generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REPLACE_WITH_YOUR_GENERATED_KEY

# ── Internal API Key (shared between backend and bot for auth) ────────────────
# Run this in terminal to generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=REPLACE_WITH_YOUR_GENERATED_KEY

# ── Discord Bot ───────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=PASTE_YOUR_NEW_BOT_TOKEN_HERE
DISCORD_CLIENT_ID=YOUR_BOT_APPLICATION_ID_HERE
DISCORD_GUILD_ID=YOUR_SERVER_ID_HERE
ADMIN_DISCORD_ID=YOUR_DISCORD_USER_ID_HERE

# Channel IDs
DISCORD_LOSS_CHANNEL=1481085508259020883
DISCORD_BOUNTY_CHANNEL=1481080748931940454
DISCORD_ESCAPE_CHANNEL=1481080862509371524
DISCORD_PAYOUT_CHANNEL=1481081607774277762

# ── Torn ─────────────────────────────────────────────────────────────────────
ADMIN_TORN_ID=4042794
# Your own Torn API key (for admin lookups)
# Bug #7 fix: was ADMIN_TORN_API_KEY but code reads ADMIN_API_KEY everywhere
ADMIN_API_KEY=PASTE_YOUR_TORN_API_KEY_HERE

# ── Backend URL (for bot → backend communication) ────────────────────────────
BACKEND_URL=http://localhost:3001
